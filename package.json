{
  "name": "webmention-feed",
  "version": "0.3.1",
  "type": "module",
  "description": "A Lit web component for fetching and displaying webmentions",
  "author": "Keiji Lohier",
  "homepage": "https://github.com/klohier/webmention-feed#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/klohier/webmention-feed.git"
  },
  "bugs": {
    "url": "https://github.com/klohier/webmention-feed/issues"
  },
  "main": "./dist/webmention-feed.js",
  "module": "./dist/webmention-feed.js",
  "types": "./dist/webmention-feed.d.ts",
  "exports": {
    ".": {
      "import": "./dist/webmention-feed.js",
      "types": "./dist/webmention-feed.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "vite",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "keywords": [
    "webmention",
    "indieweb",
    "web-component",
    "lit"
  ],
  "sideEffects": [
    "./dist/webmention-feed.js"
  ],
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "lit": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
